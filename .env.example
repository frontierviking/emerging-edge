# Emerging Edge — environment variables
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored so your keys stay private.

# Serper API key — optional. Without it, the dashboard falls back to
# direct scrapers only (no Twitter, no insider search for most exchanges,
# no news for frontier markets Yahoo Finance doesn't cover).
#
# Get a free key (2,500 credits) at: https://serper.dev/
SERPER_API_KEY=
